{% set default_working_dir = "/vllm-workspace/tests" %}
{% set list_file_diff = list_file_diff | replace("\r", "") | replace("\n", "|") | split("|") %}

{% macro amd_infra_retry(indent='') -%}
{{ indent }}retry:
{{ indent }}  automatic:
{{ indent }}    - signal_reason: agent_stop  # Agent host stopped unexpectedly
{{ indent }}      limit: 1
{{ indent }}    - signal_reason: agent_refused  # Agent could not accept the job
{{ indent }}      limit: 1
{{ indent }}    - exit_status: -1  # Lost contact with the running agent
{{ indent }}      signal_reason: none
{{ indent }}      limit: 1
{%- endmacro %}

{% macro amd_step_slug(step) -%}
{%- if step.agent_pool -%}{{ step.agent_pool }}-{%- endif -%}{{ step.label | replace(" ", "-") | lower | replace("(", "") | replace(")", "") | replace("%", "") | replace(",", "-") | replace("+", "-") }}
{%- endmacro %}

{% macro aiter_env_passthrough_patch(indent='') -%}
{{ indent }}set -eu
{{ indent }}patch_aiter_env_passthrough() {
{{ indent }}  file="$$1"
{{ indent }}  anchor="$$2"
{{ indent }}  insert="$$3"
{{ indent }}  if [ ! -f "$$file" ]; then
{{ indent }}    echo "Skipping AITER env passthrough patch; $$file not found"
{{ indent }}    return 0
{{ indent }}  fi
{{ indent }}  if grep -q "VLLM_ROCM_USE_AITER" "$$file"; then
{{ indent }}    echo "AITER env passthrough already present in $$file"
{{ indent }}    return 0
{{ indent }}  fi
{{ indent }}  tmp="$${file}.aiter-env"
{{ indent }}  found=0
{{ indent }}  line=""
{{ indent }}  while IFS= read -r line || [ -n "$$line" ]; do
{{ indent }}    if [ "$$found" -eq 0 ] && [ "$$line" = "$$anchor" ]; then
{{ indent }}      printf '%s\n' "$$insert"
{{ indent }}      found=1
{{ indent }}    fi
{{ indent }}    printf '%s\n' "$$line"
{{ indent }}  done < "$$file" > "$$tmp"
{{ indent }}  if [ "$$found" -eq 0 ]; then
{{ indent }}    rm -f "$$tmp"
{{ indent }}    echo "Failed to patch AITER env passthrough; anchor not found in $$file"
{{ indent }}    return 42
{{ indent }}  fi
{{ indent }}  mv "$$tmp" "$$file"
{{ indent }}  chmod +x "$$file"
{{ indent }}  echo "Patched AITER env passthrough into $$file"
{{ indent }}}
{{ indent }}patch_aiter_env_passthrough \
{{ indent }}  ".buildkite/scripts/hardware_ci/run-amd-test.sh" \
{{ indent }}  '    -e "PYTORCH_ROCM_ARCH=" \' \
{{ indent }}  '    -e "VLLM_ROCM_USE_AITER=$${VLLM_ROCM_USE_AITER:-1}" \'
{{ indent }}patch_aiter_env_passthrough \
{{ indent }}  ".buildkite/scripts/run-multi-node-test.sh" \
{{ indent }}  '            -v ~/.cache/huggingface:/root/.cache/huggingface --name "node$$node" \' \
{{ indent }}  '            -e "VLLM_ROCM_USE_AITER=$${VLLM_ROCM_USE_AITER:-1}" \'
{%- endmacro %}

{% macro checkout_workload_commit(indent='') -%}
{{ indent }}set -eu
{{ indent }}checkout_workload_commit() {
{{ indent }}  commit="{{ vllm_ci_workload_commit }}"
{{ indent }}  if [ -z "$$commit" ] || [ "$$commit" = "HEAD" ] || [ "$$commit" = "$${BUILDKITE_COMMIT:-}" ]; then
{{ indent }}    return 0
{{ indent }}  fi
{{ indent }}  ref="$${VLLM_CI_SNAPSHOT_REF:-main}"
{{ indent }}  depth="$${VLLM_CI_SNAPSHOT_FETCH_DEPTH:-2000}"
{{ indent }}  repo_dir="$$(pwd)"
{{ indent }}  git -c safe.directory="$$repo_dir" fetch --no-tags --depth="$$depth" origin "$${ref}:refs/remotes/origin/$${ref}" >/dev/null 2>&1 \
{{ indent }}    || git -c safe.directory="$$repo_dir" fetch --no-tags origin "$$commit" >/dev/null 2>&1 \
{{ indent }}    || true
{{ indent }}  git -c safe.directory="$$repo_dir" checkout --force "$$commit"
{{ indent }}  echo "Checked out workload commit: $$(git -c safe.directory="$$repo_dir" rev-parse HEAD)"
{{ indent }}}
{{ indent }}checkout_workload_commit
{%- endmacro %}

  - group: "AMD Tests"
    depends_on: ~
    steps:
      - label: "AMD: :docker: ensure ci_base"
        depends_on: ~
        soft_fail: false
        commands:
          - |
{{ checkout_workload_commit('            ') }}
            BUILDKITE_COMMIT="{{ vllm_ci_workload_commit }}" COMMIT="{{ vllm_ci_workload_commit }}" bash .buildkite/scripts/ci-bake-rocm.sh ci-base-rocm-ci-with-deps
        key: "amd-ci-base-ready"
        env:
          DOCKER_BUILDKIT: "1"
          VLLM_BAKE_FILE: "docker/docker-bake-rocm.hcl"
          PYTORCH_ROCM_ARCH: "gfx90a;gfx942;gfx950"
          REMOTE_VLLM: "1"
          VLLM_BRANCH: "{{ vllm_ci_workload_commit }}"
{{ amd_infra_retry('        ') }}
        agents:
          queue: amd-cpu

      - label: "AMD: :docker: build image"
        depends_on: "amd-ci-base-ready"
        soft_fail: false
        commands:
          - |
{{ checkout_workload_commit('            ') }}
            if [ "${ROCM_CI_ARTIFACT_ONLY:-0}" = "1" ]; then
              echo "ROCM_CI_ARTIFACT_ONLY=1; building ROCm wheel artifact only"
              IMAGE_TAG="" BUILDKITE_COMMIT="{{ vllm_ci_workload_commit }}" COMMIT="{{ vllm_ci_workload_commit }}" bash .buildkite/scripts/ci-bake-rocm.sh test-rocm-ci-with-artifacts
            else
              BUILDKITE_COMMIT="{{ vllm_ci_workload_commit }}" COMMIT="{{ vllm_ci_workload_commit }}" bash .buildkite/scripts/ci-bake-rocm.sh test-rocm-ci-with-wheel
            fi
        key: "amd-build"
        env:
          DOCKER_BUILDKIT: "1"
          VLLM_BAKE_FILE: "docker/docker-bake-rocm.hcl"
          PYTORCH_ROCM_ARCH: "gfx90a;gfx942;gfx950"
          IMAGE_TAG: "{{ vllm_ci_workload_image }}"
          REMOTE_VLLM: "1"
          VLLM_BRANCH: "{{ vllm_ci_workload_commit }}"
{{ amd_infra_retry('        ') }}
        agents:
          queue: amd-cpu

    {% for step in steps %}
    {% if step.mirror_hardwares and mirror_hw in step.mirror_hardwares %}

    {% set ns = namespace(blocked=1) %}
    {% set step_slug = amd_step_slug(step) %}
    {% set container_timeout_s = (step.timeout_in_minutes * 60 - 60) if step.timeout_in_minutes and step.timeout_in_minutes > 1 else (step.timeout_in_minutes * 60 if step.timeout_in_minutes else none) %}

    {% if run_all == "1" or nightly == "1" %}
    {% set ns.blocked = 0 %}
    {% endif %}

      {% if step.source_file_dependencies %}
        {% for source_file in step.source_file_dependencies %}
          {% for file in list_file_diff %}
            {% if file and file[:source_file|length] == source_file %}
              {% set ns.blocked = 0 %}
            {% endif %}
          {% endfor %}
        {% endfor %}
      {% else %}
        {% set ns.blocked = 0 %}
      {% endif %}

      {% if (ns.blocked == 1 or (step.optional and nightly != "1")) and not (step.autorun_on_main == true and branch == "main") %}
      - block: "Run {{ step.agent_pool }}: {{ step.label }}"
        depends_on: amd-build
        key: block-{{ step_slug }}
      {% endif %}

      - label: "{{ step.agent_pool }}: {{ step.label }}"
      {% if (ns.blocked == 1 or (step.optional and nightly != "1")) and not (step.autorun_on_main == true and branch == "main") %}
        depends_on: block-{{ step_slug }}
        {% else %}
        depends_on: amd-build
        {% endif %}
        {% if step.timeout_in_minutes %}
        timeout_in_minutes: {{ step.timeout_in_minutes }}
        {% endif %}
        agents:
          {% if step.agent_pool %}
          queue: amd_{{ step.agent_pool }}
          {% else %}
          queue: amd_mi300
          {% endif %}
        command: |
{{ checkout_workload_commit('          ') }}
{{ aiter_env_passthrough_patch('          ') }}
          bash .buildkite/scripts/hardware_ci/run-amd-test.sh
        env:
          DOCKER_BUILDKIT: "1"
          NUM_NODES: "{{ step.num_nodes or 1 }}"
          # Agent hooks read DOCKER_IMAGE_NAME before run-amd-test.py starts.
          # Keep the hook warmup on ci_base; the runner uses the full image only
          # if ci_base or artifact setup fails before tests begin.
          DOCKER_IMAGE_NAME: "rocm/vllm-dev:ci_base"
          VLLM_CI_BASE_IMAGE: "rocm/vllm-dev:ci_base"
          VLLM_CI_FALLBACK_IMAGE: "{{ vllm_ci_workload_image }}"
          VLLM_CI_USE_ARTIFACTS: "1"
          VLLM_CI_ARTIFACT_GLOB: "artifacts/vllm-rocm-install/vllm-rocm-install.tar.gz"
          VLLM_CI_RESULTS_ROOT: "/home/buildkite-agent/huggingface/amd-ci-results"
          {% if container_timeout_s %}
          CONTAINER_TIMEOUT_S: "{{ container_timeout_s }}"
          {% endif %}
          {% if step.num_nodes and step.num_nodes >= 2 %}
          VLLM_CI_EXECUTION_MODE: "multi-node"
          VLLM_NUM_GPUS_PER_NODE: "{{ step.num_gpus or 1 }}"
          VLLM_NODE_COMMAND_COUNT: "{{ step.commands | length }}"
          {% for node_command in step.commands %}
          VLLM_NODE_COMMAND_{{ loop.index0 }}: "(command rocm-smi || true) && export VLLM_TEST_GROUP_NAME={{ step_slug }}-node{{ loop.index0 }} && export VLLM_ALLOW_DEPRECATED_BEAM_SEARCH=1 && cd {{ (step.working_dir or default_working_dir) | safe }} && {{ node_command | replace('\"', '\\\"') | safe }}"
          {% endfor %}
          {% else %}
          VLLM_CI_EXECUTION_MODE: "single-node"
          VLLM_TEST_COMMANDS: "(command rocm-smi || true) && export VLLM_TEST_GROUP_NAME={{ step_slug }} && export VLLM_ALLOW_DEPRECATED_BEAM_SEARCH=1 && cd {{ (step.working_dir or default_working_dir) | safe }} && {{ (step.command or (step.commands | join(' && '))) | replace('\"', '\\\"') | safe }}"
          {% endif %}
        priority: 100
        {% if step.grade and step.grade == "Blocking" %}
        soft_fail: false
        {% else %}
        soft_fail: true
        {% endif %}
        {% if step.parallelism %}
        parallelism: {{ step.parallelism }}
        {% endif %}
{{ amd_infra_retry('        ') }}
    {% endif %}
    {% endfor %}
